# pyenv
#   For a library or app, you might want to share your .python-version.
#   See: https://github.com/pyenv/pyenv/blob/master/COMMANDS.md#pyenv-version-file
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git
#   but we should ignore the virtualenv if it is inside the project
#.venv
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is associated with the project version
#   but we should ignore virtualenvs
.venv/
poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is associated with the project version
.pdm-plugins/
.pdm-build/

# pipproject
#  pdm lockfile
pdm.lock

# venv
#   Useful for ignoring virtual environments created using python -m venv
venv/
ENV/
env/
.venv/

